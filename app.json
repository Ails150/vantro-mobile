{
  "expo": {
    "name": "Vantro",
    "slug": "vantro",
    "version": "1.2.2",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f1923",
    "splash": {
      "backgroundColor": "#0f1923"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.getvantro.app",
      "buildNumber": "10",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Vantro needs your location to verify you are on site before signing in.",
        "NSCameraUsageDescription": "Vantro needs camera access to capture QA photos and defect evidence.",
        "NSPhotoLibraryUsageDescription": "Vantro needs photo library access to attach images to reports.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Vantro detects when you arrive at or leave a job site so your attendance is logged accurately, even if you forget to sign out. We only check your location at the site boundary - no continuous tracking."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f1923"
      },
      "package": "com.getvantro.app",
      "versionCode": 18,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyArSljqX_4JhcVIVk-P8xs8YNFCCYyOCYs"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "Vantro needs your location to verify you are on site.",
          "locationAlwaysPermission": "Vantro tracks your location while signed in to verify attendance."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Vantro needs camera access for QA photos."
        }
      ],
      "expo-task-manager",
      "expo-video",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "vantro-mobile",
          "organization": "scale-8"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "edgeToEdgeEnabled": true,
            "minSdkVersion": 24
          }
        }
      ],
      "react-native-edge-to-edge"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1e578303-87f6-41d8-9abc-7b9f135f2ff0"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1e578303-87f6-41d8-9abc-7b9f135f2ff0"
    },
    "scheme": "vantro"
  }
}
